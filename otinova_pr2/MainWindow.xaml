<Window x:Class="otinova_pr2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор" Height="470" Width="350"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FontFamily="Segoe UI"
        WindowStyle="SingleBorderWindow"
        Background="#FFF8F0F0">

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Выражение и результат -->
        <Border Grid.Row="0" 
                BorderBrush="#FFD9C5C5" 
                BorderThickness="1" 
                CornerRadius="3" 
                Margin="0,0,0,10"
                Background="White">
            <StackPanel>
                <TextBox x:Name="ExpressionBox" 
                         Height="25" 
                         FontSize="14" 
                         TextAlignment="Right" 
                         BorderThickness="0"
                         IsReadOnly="True"
                         Background="White"
                         Text=""
                         Padding="2"/>
                <TextBox x:Name="ResultBox" 
                         Height="45" 
                         FontSize="28" 
                         FontWeight="Bold"
                         TextAlignment="Right" 
                         BorderThickness="0"
                         IsReadOnly="False"
                         Background="White"
                         Text="0"
                         Padding="2"/>
            </StackPanel>
        </Border>

        <!-- Кнопки -->
        <UniformGrid Grid.Row="1" Rows="5" Columns="4" Margin="0">

            <!-- Строка 1 -->
            <Button Content="C" Click="ClearButton_Click" FontSize="20" Margin="1" Background="#FFE8C5C5"/>
            <Button Content="(" Click="Button_Click" FontSize="20" Margin="1" Background="#FFEDE0E0"/>
            <Button Content=")" Click="Button_Click" FontSize="20" Margin="1" Background="#FFEDE0E0"/>
            <Button Content="^" Click="Button_Click" FontSize="20" Margin="1" Background="#FFEDE0E0"/>

            <!-- Строка 2 -->
            <Button Content="7" Click="Button_Click" FontSize="20" Margin="1" Background="#FFF5E8E8"/>
            <Button Content="8" Click="Button_Click" FontSize="20" Margin="1" Background="#FFF5E8E8"/>
            <Button Content="9" Click="Button_Click" FontSize="20" Margin="1" Background="#FFF5E8E8"/>
            <Button Content="/" Click="Button_Click" FontSize="20" Margin="1" Background="#FFE8D5D5"/>

            <!-- Строка 3 -->
            <Button Content="4" Click="Button_Click" FontSize="20" Margin="1" Background="#FFF5E8E8"/>
            <Button Content="5" Click="Button_Click" FontSize="20" Margin="1" Background="#FFF5E8E8"/>
            <Button Content="6" Click="Button_Click" FontSize="20" Margin="1" Background="#FFF5E8E8"/>
            <Button Content="*" Click="Button_Click" FontSize="20" Margin="1" Background="#FFE8D5D5"/>

            <!-- Строка 4 -->
            <Button Content="1" Click="Button_Click" FontSize="20" Margin="1" Background="#FFF5E8E8"/>
            <Button Content="2" Click="Button_Click" FontSize="20" Margin="1" Background="#FFF5E8E8"/>
            <Button Content="3" Click="Button_Click" FontSize="20" Margin="1" Background="#FFF5E8E8"/>
            <Button Content="-" Click="Button_Click" FontSize="20" Margin="1" Background="#FFE8D5D5"/>

            <!-- Строка 5 -->
            <Button Content="0" Click="Button_Click" FontSize="20" Margin="1" Background="#FFF5E8E8"/>
            <Button Content="." Click="Button_Click" FontSize="20" Margin="1" Background="#FFF5E8E8"/>
            <Button Content="=" Click="EqualsButton_Click" FontSize="20" Margin="1" Background="#FFE8C5C5"/>
            <Button Content="+" Click="Button_Click" FontSize="20" Margin="1" Background="#FFE8D5D5"/>

        </UniformGrid>
    </Grid>
</Window>